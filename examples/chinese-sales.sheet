# 中文示例：表名、列名、计算列和图表依赖都使用 Unicode 标识符。
@meta
title: 中文销售报表
owner: 示例

@plugin 财务插件
path: ./plugins/finance.ts
exports: tax

@table 销售表
地区[string],商品[string],单价[number],数量[number],销售额[number]
华北,苹果,3,5,15
华东,香蕉,2,8,16
华南,橙子,4,6,24

@compute 销售表
target: 含税销售额[number], 平均数量[number]
含税销售额 = 财务插件.tax(单价, 数量)
平均数量 = avg(数量)


@plot 销售表
deps: 销售额,含税销售额
x: 销售额
y: 含税销售额
title: 销售额与含税销售额
